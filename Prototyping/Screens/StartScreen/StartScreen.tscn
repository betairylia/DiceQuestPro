[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://Prototyping/Screens/StartScreen/start_screen.gd" id="1"]
[ext_resource type="Theme" path="res://Prototyping/HUD/pixelated.tres" id="2"]

[node name="StartScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2")
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.03, 0.03, 0.04, 1)

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = 12.0
offset_right = -16.0
offset_bottom = -12.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2

[node name="TitleLabel" type="RichTextLabel" parent="MarginContainer/VBox"]
layout_mode = 2
bbcode_enabled = true
fit_content = true
scroll_active = false
theme_override_font_sizes/normal_font_size = 18
text = "[center]DiceQuestPro\nRoguelike Run[/center]"

[node name="StatusLabel" type="RichTextLabel" parent="MarginContainer/VBox"]
layout_mode = 2
bbcode_enabled = true
fit_content = true
scroll_active = false
text = "[center]选择 1-3 名角色出发[/center]"

[node name="Scroll" type="ScrollContainer" parent="MarginContainer/VBox"]
custom_minimum_size = Vector2(0, 220)
layout_mode = 2
size_flags_vertical = 3

[node name="Grid" type="GridContainer" parent="MarginContainer/VBox/Scroll"]
layout_mode = 2
size_flags_horizontal = 3
columns = 3
theme_override_constants/h_separation = 10
theme_override_constants/v_separation = 10

[node name="SelectedLabel" type="RichTextLabel" parent="MarginContainer/VBox"]
layout_mode = 2
bbcode_enabled = true
fit_content = true
scroll_active = false
text = "[center]尚未选择角色[/center]"

[node name="DepartButton" type="Button" parent="MarginContainer/VBox"]
layout_mode = 2
text = "出发"

[connection signal="pressed" from="MarginContainer/VBox/DepartButton" to="." method="_on_depart_button_pressed"]
