[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://Prototyping/Screens/Combat/combat_screen.gd" id="1"]
[ext_resource type="Theme" path="res://Prototyping/HUD/pixelated.tres" id="2"]

[node name="CombatScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2")
script = ExtResource("1")

[node name="CombatRoot" type="Control" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="DefeatOverlay" type="PanelContainer" parent="."]
visible = false
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -110.0
offset_top = -55.0
offset_right = 110.0
offset_bottom = 55.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="DefeatOverlay"]
layout_mode = 2

[node name="TitleLabel" type="RichTextLabel" parent="DefeatOverlay/VBox"]
layout_mode = 2
bbcode_enabled = true
fit_content = true
scroll_active = false
text = "[center]战斗失败[/center]"

[node name="RetryButton" type="Button" parent="DefeatOverlay/VBox"]
layout_mode = 2
text = "重试"

[node name="GiveUpButton" type="Button" parent="DefeatOverlay/VBox"]
layout_mode = 2
text = "放弃"

[connection signal="pressed" from="DefeatOverlay/VBox/RetryButton" to="." method="_on_retry_button_pressed"]
[connection signal="pressed" from="DefeatOverlay/VBox/GiveUpButton" to="." method="_on_give_up_button_pressed"]
